main:
  LI R1, 12
  LI R2, 5

  ADD R3, R1, R2
  SUB R4, R1, R2
  AND R5, R1, R2
  OR  R6, R1, R2
  XOR R7, R1, R2
  MOV R2, R1

  LI R6, 1
  SHL R3, R1, R6
  SHR R4, R1, R6

  HALT

